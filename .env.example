# ============================================================
# Phína — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# --- Client-side (embedded in JS bundle) --------------------
# These are prefixed with EXPO_PUBLIC_ and are visible to
# anyone who inspects the app. They are NOT secret — Supabase
# anon key is designed to be public (RLS enforces security).
#
# In Supabase: Connect dialog (Mobile → Expo React Native) or Project Settings → API:
#   - "Project URL" → EXPO_PUBLIC_SUPABASE_URL
#   - Use EITHER anon key OR publishable key (see API Keys docs):
#     EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...  (Legacy API Keys → anon)
#     EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...  (API Keys → Publishable)
# NEVER put the "service_role" / secret key here (client-only).

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key
# EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...  # optional; anon key also works
EXPO_PUBLIC_APP_URL=https://phina.appsmithery.co
# EAS/Expo project UUID (expo.dev → project → overview). Used for native push token registration. If unset, app.config.ts fallback is used.
# EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-uuid
EXPO_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# --- Observability -------------------------------------------
# Sentry DSN: Sentry project → Settings → Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id
# PostHog project API key: PostHog → Project Settings → Project API Key
EXPO_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
# PostHog ingestion host (leave as default unless self-hosting)
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# SENTRY_AUTH_TOKEN is set as an EAS secret (not here) for source map upload at build time:
# eas secret:create --scope project --name SENTRY_AUTH_TOKEN --value <your-token>

# --- Google Sign-In (native builds) --------------------------
# Required for the native Google Sign-In SDK (@react-native-google-signin/google-signin).
# These are not secret — they are safe to expose in the app bundle.
# Get these from Google Cloud Console → APIs & Services → Credentials.
#
# Web client ID (type: Web application) — used on all platforms including mobile
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# iOS client ID (type: iOS, bundle ID: co.appsmithery.phina)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
# iOS URL scheme = reversed iOS client ID (com.googleusercontent.apps.YOUR_IOS_CLIENT_ID)
# Also set in app.config.ts plugins -> @react-native-google-signin/google-signin -> iosUrlScheme
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.your-ios-client-id

# --- Billing / Monetization ---------------------------------
# RevenueCat public SDK configuration for native iOS purchases.
# Configure these in RevenueCat after creating:
#   - a "premium" entitlement
#   - a monthly package in the current offering
#   - a consumable host-credit product
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_...your-revenuecat-ios-sdk-key
EXPO_PUBLIC_REVENUECAT_PREMIUM_PACKAGE_ID=$rc_monthly
EXPO_PUBLIC_REVENUECAT_HOST_CREDIT_PRODUCT_ID=phina_host_credit_1
# Optional: keep the default "premium" entitlement ID unless you rename it in RevenueCat.
# EXPO_PUBLIC_REVENUECAT_PREMIUM_ENTITLEMENT_ID=premium

# --- Server-side only (Supabase Edge Functions) -------------
# These must NEVER appear in client code or env vars prefixed
# with EXPO_PUBLIC_. They are set via `supabase secrets set`.

# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key
# PERPLEXITY_API_KEY=pplx-...your-perplexity-key  (for label extraction Edge Function)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SIGNING_SECRET=whsec_...
# STRIPE_PREMIUM_PRICE_ID=price_...
# STRIPE_HOST_CREDIT_PRICE_ID=price_...
# REVENUECAT_WEBHOOK_AUTH=your-shared-webhook-secret
# REVENUECAT_HOST_CREDIT_PRODUCT_ID=phina_host_credit_1
# REVENUECAT_PREMIUM_ENTITLEMENT_ID=premium
# For Web Push (PWA): generate with `npx @pushforge/builder vapid` and set the *private* key (full JWK JSON string):
# VAPID_PRIVATE_KEY={"kty":"EC","crv":"P-256","x":"...","y":"...","d":"..."}

# --- CI/CD (GitHub Actions secrets) -------------------------
# These are set in GitHub repo Settings > Secrets, never here.

# VERCEL_TOKEN=...
# VERCEL_ORG_ID=...
# VERCEL_PROJECT_ID=...
# EXPO_TOKEN=...
