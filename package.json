{
  "name": "phina",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eas:env:push:preview": "bash scripts/push-env-to-eas.sh --env preview --apply",
    "eas:env:push:production": "bash scripts/push-env-to-eas.sh --env production --apply",
    "eas:env:verify:preview:ios": "node scripts/verify-eas-env.mjs --environment preview --platform ios",
    "eas:env:verify:preview:android": "node scripts/verify-eas-env.mjs --environment preview --platform android",
    "eas:env:verify:preview:all": "npm run eas:env:verify:preview:ios && npm run eas:env:verify:preview:android",
    "eas:env:verify:production:all": "node scripts/verify-eas-env.mjs --environment production --platform all",
    "build:preview:ios": "npm run eas:env:push:preview && npm run eas:env:verify:preview:ios && npx eas build --platform ios --profile preview",
    "build:preview:android": "npm run eas:env:push:preview && npm run eas:env:verify:preview:android && npx eas build --platform android --profile preview",
    "build:preview:all": "npm run build:preview:ios && npm run build:preview:android",
    "export:web": "expo export --platform web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "supabase": "supabase",
    "functions:serve": "supabase functions serve extract-wine-label",
    "functions:serve:billing": "supabase functions serve create-stripe-checkout-session billing-stripe-webhook billing-revenuecat-webhook",
    "functions:deploy:create-stripe-checkout-session": "supabase functions deploy create-stripe-checkout-session --use-api",
    "functions:deploy:billing-stripe-webhook": "supabase functions deploy billing-stripe-webhook --no-verify-jwt --use-api",
    "functions:deploy:billing-revenuecat-webhook": "supabase functions deploy billing-revenuecat-webhook --no-verify-jwt --use-api",
    "functions:deploy:delete-account": "supabase functions deploy delete-account --use-api",
    "functions:deploy:extract-wine-label": "supabase functions deploy extract-wine-label --no-verify-jwt --use-api",
    "functions:deploy:generate-bottle-image": "supabase functions deploy generate-bottle-image --no-verify-jwt --use-api",
    "functions:deploy:generate-event-image": "supabase functions deploy generate-event-image --no-verify-jwt --use-api",
    "functions:deploy:generate-wine-summary": "supabase functions deploy generate-wine-summary --no-verify-jwt --use-api",
    "functions:deploy:send-rating-round-push": "supabase functions deploy send-rating-round-push --use-api"
  },
  "dependencies": {
    "@expo-google-fonts/montserrat": "^0.4.2",
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/slider": "5.0.1",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@react-navigation/native": "^7.0.0",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-query": "^5.59.0",
    "expo": "^54.0.0",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.10",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "posthog-react-native": "^4.36.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-purchases": "^9.11.2",
    "react-native-qrcode-svg": "^6.3.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.8.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-plugin-expo": "^1.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "jose": "^5.9.6",
    "react-test-renderer": "19.1.0",
    "supabase": "^2.15.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "minimatch": ">=10.2.1",
    "tar": ">=7.5.8"
  },
  "private": true
}
